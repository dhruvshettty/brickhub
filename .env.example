# === REQUIRED ===
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# === DATABASE ===
# Native dev (no Docker): uses SQLite by default — leave this unset
# Docker: set to postgresql://brickhub:${POSTGRES_PASSWORD}@db:5432/brickhub
# DATABASE_URL=sqlite:///./brickhub.db

# Docker only — pick any secure password for the local Postgres instance
POSTGRES_PASSWORD=changeme_local_only

# === OPTIONAL (Milestone 3: Strava sync) ===
# Register at strava.com/settings/api → create an app
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# === OPTIONAL (future: multi-user / production) ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
