# === REQUIRED ===
# Get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# === DATABASE ===
# Native dev (no Docker): uses SQLite by default — leave this unset
# Docker: set to postgresql://brickhub:${POSTGRES_PASSWORD}@db:5432/brickhub
# DATABASE_URL=sqlite:///./brickhub.db

# Docker only — pick any secure password for the local Postgres instance
POSTGRES_PASSWORD=changeme_local_only

# === STRAVA ACTIVITY SYNC (optional) ===
# Auto-imports completed runs so you don't mark sessions done by hand.
# Register an app at strava.com/settings/api with Authorization Callback Domain = localhost,
# then paste the Client ID + Secret below and restart. Free with any Strava subscription.
# On the consent screen, keep "View private activities" checked or private runs won't import.
# Leave blank to disable — the Settings → Strava card just shows "not configured".
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# === SESSION SECRET (optional) ===
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
